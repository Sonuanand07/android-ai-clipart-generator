{
  "expo": {
    "name": "ClipMint AI",
    "slug": "clipmint-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "clipmint",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFF8EF"
    },
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "package": "com.flickd.clipmint",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFF8EF"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "ClipMint uses your photos so you can turn portraits into AI clipart.",
          "cameraPermission": "ClipMint uses your camera so you can capture a portrait to stylize."
        }
      ],
      [
        "expo-media-library",
        {
          "savePhotosPermission": "ClipMint saves generated PNG clipart to your gallery."
        }
      ],
      "expo-font"
    ],
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
